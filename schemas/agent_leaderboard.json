{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Arena Agent Leaderboard",
  "type": "object",
  "required": ["meta", "models"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": ["leaderboard", "source_url", "fetched_at", "model_count", "dimensions"],
      "additionalProperties": false,
      "properties": {
        "leaderboard": { "type": "string", "const": "agent" },
        "source_url": { "type": "string", "format": "uri" },
        "fetched_at": { "type": "string", "format": "date-time" },
        "last_updated": { "type": ["string", "null"] },
        "model_count": { "type": "integer", "minimum": 1 },
        "dimensions": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
      }
    },
    "models": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/model" } }
  },
  "$defs": {
    "score_entry": {
      "type": "object",
      "required": ["name", "score", "ci"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "score": { "type": ["number", "null"] },
        "ci": { "type": ["number", "null"] }
      }
    },
    "model": {
      "type": "object",
      "required": ["rank", "model", "vendor", "license", "scores", "sessions"],
      "additionalProperties": false,
      "properties": {
        "rank": { "type": "integer", "minimum": 1 },
        "model": { "type": "string", "minLength": 1 },
        "vendor": { "type": ["string", "null"] },
        "license": { "enum": ["proprietary", "open", null] },
        "scores": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/score_entry" } },
        "sessions": { "type": ["integer", "null"], "minimum": 1 }
      }
    }
  }
}
